<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/option_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/option_min_height"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_option_default"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_primary"
    android:padding="@dimen/spacing_md">

    <!-- Option letter badge (A, B, C, D) -->
    <TextView
        android:id="@+id/tv_option_letter"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="A"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/primary"
        android:background="@drawable/bg_circle"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Option text -->
    <TextView
        android:id="@+id/tv_option_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Option text goes here"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_option_letter"
        app:layout_constraintEnd_toStartOf="@id/iv_result_icon" />

    <!-- Result icon (check / cross) -->
    <ImageView
        android:id="@+id/iv_result_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:contentDescription="Answer status"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

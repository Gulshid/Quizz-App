<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="@dimen/category_card_height"
    android:layout_margin="6dp"
    android:foreground="@drawable/ripple_primary"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/spacing_md">

        <!-- Color accent bar -->
        <View
            android:id="@+id/accent_bar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Icon background -->
        <FrameLayout
            android:id="@+id/icon_bg"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🔬"
                android:textSize="24sp"
                android:gravity="center" />
        </FrameLayout>

        <!-- Category name -->
        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Science"
            android:textSize="17sp"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/icon_bg"
            app:layout_constraintStart_toEndOf="@id/icon_bg"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Physics, Chemistry &amp; Biology"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_category_name"
            app:layout_constraintStart_toEndOf="@id/icon_bg"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp" />

        <!-- Bottom row: question count + difficulty + play -->
        <TextView
            android:id="@+id/tv_question_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 Questions"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/tv_difficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medium"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/warning"
            android:background="@drawable/bg_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_question_count"
            android:layout_marginStart="8dp" />

        <!-- Play arrow -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:fontFamily="@font/poppins_bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="4dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
